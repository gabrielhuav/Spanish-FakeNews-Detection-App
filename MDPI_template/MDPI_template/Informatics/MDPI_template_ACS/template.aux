\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Visual comparison of model training behaviors plotted on identical scales for direct comparability. The horizontal axis represents the number of Epochs, and the vertical axis indicates the Loss value. (a) Illustrates \textbf  {overfitting}, where the model memorizes the training data (blue line decreases) but fails to generalize to new data (red validation line increases). (b) Illustrates \textbf  {underfitting}, characterized by the inability of the model to capture underlying patterns, resulting in high loss values for both curves.}}{9}{figure.caption.9}\protected@file@percent }
\newlabel{fig:overfitting_underfitting_examples}{{4}{9}{Visual comparison of model training behaviors plotted on identical scales for direct comparability. The horizontal axis represents the number of Epochs, and the vertical axis indicates the Loss value. (a) Illustrates \textbf {overfitting}, where the model memorizes the training data (blue line decreases) but fails to generalize to new data (red validation line increases). (b) Illustrates \textbf {underfitting}, characterized by the inability of the model to capture underlying patterns, resulting in high loss values for both curves}{figure.caption.9}{}}
\newlabel{fig:overfitting_underfitting_examples@cref}{{[figure][4][]4}{[1][9][]9}{}{}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(\normalfont (\textbf {a}))}{\ignorespaces {Overfitting scenario: Validation loss diverges while training loss decreases.}}}{9}{subfigure.4.1}\protected@file@percent }
